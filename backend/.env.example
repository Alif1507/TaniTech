# TaniTech Backend Environment Variables Example

# Supabase URL (already configured for project cdmgrxwbobiyorddcmes)
SUPABASE_URL=https://cdmgrxwbobiyorddcmes.supabase.co

# Supabase Anon Key (Public Key, safe to commit)
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImNkbWdyeHdib2JpeW9yZGRjbWVzIiwicm9sZSI6ImFub24iLCJpYXQiOjE3ODQxOTA0NzcsImV4cCI6MjA5OTc2NjQ3N30.YyumqKD4n4MIARqsm7W0mS4t2_Ra8iYGRvFuMlqPrMs

# Supabase Service Role Key (Needed for bypass RLS and Auth Admin features. Optional, fallback to Anon Key if empty)
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Groq API Key (For AI Assistant recommendations and digital twin simulations. If empty, the app runs with simulated mocks)
GROQ_API_KEY=your_groq_api_key_here

# Groq AI Models (Defaults match PRD requirements)
GROQ_DEFAULT_MODEL=openai/gpt-oss-20b
GROQ_REASONING_MODEL=qwen/qwen3.6-27b

# Internal Cron Secret (Required to authorize manual weather warning cron endpoint executions)
INTERNAL_CRON_SECRET=super_secret_cron_key
